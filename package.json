{
	"name": "tags-bot",
	"version": "1.0.0",
	"description": "",
	"main": "index.js",
	"type": "module",
	"scripts": {
		"dev": "tsx --watch src/index.ts",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write --unsafe .",
		"format": "biome format --write .",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"deploy-commands": "tsx scripts/deploy-commands.ts",
		"typecheck": "tsc --noEmit",
		"build": "rm -rf dist && NODE_ENV=production tsc --noEmit false --outDir dist && tsc-alias",
		"start": "node dist/src/index.js",
		"prisma:generate": "prisma generate",
		"migrate:deploy": "prisma migrate deploy"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.33.2",
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^25.6.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.2",
		"prisma": "^7.8.0",
		"tsc-alias": "^1.8.17",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@prisma/adapter-better-sqlite3": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"discord.js": "^14.26.4",
		"dotenv": "^17.4.2",
		"lru-cache": "^11.3.6",
		"tsx": "^4.21.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3"
		]
	},
	"lint-staged": {
		"*.{ts,js}": [
			"biome format --write",
			"biome lint --fix"
		]
	}
}
