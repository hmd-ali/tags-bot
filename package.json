{
  "name": "tags-bot",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsc --noEmit",
    "deploy-commands": "tsx scripts/deploy-commands.ts",
    "build": "rm -rf dist && NODE_ENV=production tsc --noEmit false --outDir dist && tsc-alias",
    "start": "node dist/src/index.js",
    "prisma:generate": "prisma generate",
    "migrate:deploy": "prisma migrate deploy",
    "prepare": "husky"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "lru-cache": "^11.3.6",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.24.0",
    "prisma": "^7.8.0",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,ts}": "pnpm run lint",
    "*.{js,ts,json}": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
